# Database (PostgreSQL — Supabase, Neon, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/last_mile_delivery?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/last_mile_delivery?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-string"

# App URL (used in notification links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email — Resend (https://resend.com/api-keys)
# Free tier: 100 emails/day. Without a key, emails log to the server console.
RESEND_API_KEY=""
# Use onboarding@resend.dev for local testing, or your verified domain in production
FROM_EMAIL="onboarding@resend.dev"

# SMS — Twilio trial (optional; logs to console when unset)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
